class Solution:
    def merge(self, nums1: list[int], m: int, nums2: list[int], n: int) -> None:
        """
        Do not return anything, modify nums1 in-place instead.
        """
        # 1. Initialize pointers
        # i: points to the last actual element in nums1
        # j: points to the last element in nums2
        # k: points to the very last index in nums1 (total capacity)
        i, j, k = m - 1, n - 1, m + n - 1
        
        # 2. Iterate while there are elements in nums2 to merge
        while j >= 0:
            # If nums1 still has elements and its current element is larger
            if i >= 0 and nums1[i] > nums2[j]:
                nums1[k] = nums1[i]
                i -= 1
            else:
                # Otherwise, place the element from nums2
                nums1[k] = nums2[j]
                j -= 1
            k -= 1
