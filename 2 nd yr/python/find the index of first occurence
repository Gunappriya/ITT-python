class Solution:
    def strStr(self, haystack: str, needle: str) -> int:
        n = len(haystack)   # length of haystack
        m = len(needle)     # length of needle

        # loop through haystack
        for i in range(n - m + 1):
            j = 0

            # compare characters
            while j < m and haystack[i + j] == needle[j]:
                j += 1

            # if full match found
            if j == m:
                return i

        return -1   # not found
