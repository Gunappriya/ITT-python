class Solution:
    def areSimilar(self, mat: list[list[int]], k: int) -> bool:
        # Get dimensions
        num_rows = len(mat)
        num_cols = len(mat[0])
        
        # Optimize k: shifting by k is same as shifting by k % num_cols
        k = k % num_cols
        
        # If k is 0, no change occurs, so it must be similar
        if k == 0:
            return True

        for i in range(num_rows):
            for j in range(num_cols):
                # The problem typically defines:
                # Even rows (0, 2, ...) shift LEFT
                # Odd rows (1, 3, ...) shift RIGHT
                
                # Check if current element matches the one 'k' positions away
                # In Python, (j + k) % num_cols works for both directions 
                # because the rows must be periodic for the matrix to stay the same.
                if mat[i][j] != mat[i][(j + k) % num_cols]:
                    return False
        
        return True
